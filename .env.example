DISCORD_TOKEN=
# application ID == client ID
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# discord user ID with owner-level bot permissions
BOT_OWNER=123456789012345678

# public URL for the web dashboard (used for OAuth redirects)
API_URL=https://clouder.uwuclxdy.dev

# local address the web server binds to (default: 127.0.0.1:8080)
WEB_BIND_ADDR=127.0.0.1:8080

# OAuth redirect URI (default: {API_URL}/auth/callback)
# DISCORD_REDIRECT_URI=https://clouder.uwuclxdy.dev/auth/callback

# secret key for signing session cookies (32+ chars recommended)
# defaults to DISCORD_CLIENT_SECRET if not set
# SESSION_SECRET=

DATABASE_URL=sqlite:data/db.sqlite

# supports hex (#RRGGBB, 0xRRGGBB) and decimal
EMBED_DEFAULT_COLOR=#FFFFFF

# trace, debug, info, warn, error
RUST_LOG=warn,clouder=info

# LLM integration
# provider: openai, ollama (unset = disabled)
# LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=256
LLM_TIMEOUT_SECONDS=60
LLM_SYSTEM_PROMPT=
LLM_STOP=

# comma-separated discord user IDs
LLM_ALLOWED_USERS=
LLM_DM_ALLOWED_USERS=
LLM_NO_COOLDOWN_USERS=
