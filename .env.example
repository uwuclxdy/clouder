DISCORD_TOKEN=
# application ID == client ID
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# discord user ID with owner-level bot permissions
BOT_OWNER=123456789012345678

# axum web server address (default: http://127.0.0.1:3000)
API_URL=http://127.0.0.1:3000

# OAuth redirect URI (default: {API_URL}/auth/callback)
# DISCORD_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Secret key for signing session cookies (32+ chars recommended)
# Defaults to DISCORD_CLIENT_SECRET if not set — it's recommended to set this explicitly
# SESSION_SECRET=

DATABASE_URL=sqlite:data/db.sqlite

# supports hex (#RRGGBB, 0xRRGGBB) and decimal
EMBED_DEFAULT_COLOR=#FFFFFF

# trace, debug, info, warn, error
RUST_LOG=warn,clouder=info

# LLM Integration

# OpenAI compatible API
OPENAI_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=256
OPENAI_TIMEOUT_SECONDS=60
OPENAI_SYSTEM_PROMPT="You are a helpful Discord bot assistant. Respond concisely and friendly."
OPENAI_STOP=

# comma-separated discord user IDs that are allowed to use the AI chatbot
OPENAI_ALLOWED_USERS=
OPENAI_DM_ALLOWED_USERS=
OPENAI_NO_COOLDOWN_USERS=
